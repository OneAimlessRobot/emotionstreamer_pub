static void set_up_socks(con_t* con_obj){



        client_udp_sock= socket(AF_INET,SOCK_DGRAM,0);
        if(client_udp_sock==-1){
                raise(SIGINT);
        }
	print_addr_aux("End. do server agora:",&server_ip_address);



        printf(CONNECTION_ESTABLISHED_MSG,inet_ntoa(server_ip_address.sin_addr));

}

static void greet_server(con_t* con_obj){

 	uint8_t client_data[DEF_DATASIZE+1]={0};
	con_read_tcp(con_obj,SERVER_DATA_TIMES_PAIR);

	sscanf(con_obj->data,"%s %h",client_data,&(con_obj->peer_udp_addr.sin_port));

	clean_con_data(con_obj);

	int result=strings_are_strictly_equal(CON_STRING,client_data);

	snprintf(con_obj->data,DEF_DATASIZE,"%h",result ? -1 : con_obj->this_udp_addr.sin_port);

	con_send_tcp(con_obj,SERVER_DATA_TIMES_PAIR);

	clean_con_data(con_obj);

}

static void greet_client(con_t* con_obj){

	uint8_t server_udp_port=0;
	snprintf(con_obj->data,DATASIZE,"%s %h",CON_STRING,con_obj->this_udp_addr.sin_port)

	con_send_tcp(con_obj,CLIENT_DATA_TIMES_PAIR);

	clean_con_data(con_obj);

	con_read_tcp(con_obj,CLIENT_DATA_TIMES_PAIR);

	sscanf(con_obj->data,"%h",client_data,&(con_obj->peer_udp_addr.sin_port));

	if(con_obj->peer_udp_addr.sin_port<0){

		close(
	}
}


void greet(con_t*con_obj){

	switch(con_obj->type){
		case SERVER_C:
			greet_server(con_obj);
			break;
		case CLIENT_C:
			greet_client(con_obj);
			break;
		default:
			break;
	}


}

