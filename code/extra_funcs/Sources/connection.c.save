void init_con(con_t* con_obj,int sockfd_tcp,con_type type){


				con_obj->is_on=1;
				con_obj->type=type;
                                con_obj->sockfd_tcp=sockfd_tcp;
                                getpeername(con_obj->sockfd_tcp, (struct sockaddr*)&(con_obj->peer_tcp_addr),&socklenvar);
				getsockname(con_obj->sockfd_tcp, (struct sockaddr*)&(con_obj->this_tcp_addr),&socklenvar);
				
				getsockname(con_obj->sockfd_tcp, (struct sockaddr*)&(con_obj->this_udp_addr),&socklenvar);
				
				con_obj->this_udp_addr.sin_port++;
				
				memset(con_obj.data_buff,0,DEF_DATASIZE+1);
                                print_addr_aux("Addresss do cliente:",&con_obj.tcp_from_addr);

}

void prep_con(con_t* con_obj){

				memset(con_obj,0,sizeof(con_t));

}

void con_send_tcp(con_t* con_obj,int_pair pair){

	sendsome(con_obj->sockfd_tcp,con_obj->data,DEF_DATASIZE,pair);
}

void con_send_udp(con_t* con_obj,int_pair pair){

	sendsome_udp(con_obj->sockfd_udp,con_obj->data,DEF_DATASIZE,pair,con_obj->peer_udp_addr);
}
void con_read_tcp(con_t* con_obj,int_pair pair){

	sendsome(con_obj->sockfd_tcp,con_obj->data,DEF_DATASIZE,pair);
}

void con_read_udp(con_t* con_obj, int_pair pair){

	sendsome_udp(con_obj->sockfd_udp,con_obj->data,DEF_DATASIZE,pair, con_obj->peer_udp_addr);
}

void clear_con_data(con_t* con_obj){

	memset(con_obj->data,0,DEF_DATASIZE+1);


}
